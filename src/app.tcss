SearchScreen {
    layout: vertical;
}

.input-row {
    layout: horizontal;
    height: 1;
    margin: 0 1;
}

.field-label {
    width: 8;
    color: #00d4aa;
    content-align: left middle;
}

.field-input {
    width: 1fr;
    margin: 0 1;
    padding: 0 2;
    background: #1a1a2e;
    color: #e0e0e0;
}

.field-input:focus {
    background: #2a2a4e;
    color: #ffffff;
}

SearchScreen > #status-bar {
    height: 1;
    background: #0a0a1a;
    color: #00d4aa;
    padding: 0 2;
}

SearchScreen > #results {
    height: 1fr;
    border: none;
    margin: 0;
}

DetailScreen {
    layout: vertical;
}

DetailScreen > #detail-status {
    height: 1;
    background: #0a0a1a;
    color: #00d4aa;
    padding: 0 2;
}

DetailScreen > #messages {
    height: 1fr;
    border: none;
}

ListView {
    background: #1a1a2e;
    color: #c0c0c0;
}

ListView > ListItem {
    padding: 0 2;
}

ListView > ListItem.-highlight {
    background: #00d4aa;
    color: #0a0a0a;
    text-style: bold;
}

#recap-box {
    background: #1a1a2e;
    color: #e0e0e0;
    padding: 0 2;
    height: auto;
}

#detail-header {
    color: #888888;
    padding: 0 2;
    height: 1;
}

#separator {
    color: #444444;
    height: 1;
}
