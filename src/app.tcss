SearchScreen {
    layout: grid;
    grid-size: 1;
    grid-rows: auto auto auto 1fr auto;
}

SearchScreen > Input {
    height: auto;
    margin: 0 1;
}

SearchScreen > Input:focus {
    border: solid #00ffcc;
}

SearchScreen > #status-bar {
    height: auto;
    background: #0a0a1a;
    color: #888888;
    padding: 0 2;
}

SearchScreen > #results {
    border: none;
}

DetailScreen {
    layout: grid;
    grid-size: 1;
    grid-rows: auto auto auto 1fr auto;
}

DetailScreen > Static {
    height: auto;
    margin: 0 1;
}

DetailScreen > #detail-status {
    height: auto;
    background: #0a0a1a;
    color: #888888;
    padding: 0 2;
}

DetailScreen > #messages {
    border: none;
}

ListView {
    background: #1a1a2e;
    color: #c0c0c0;
}

ListView > ListItem {
    padding: 0 2;
}

ListView > ListItem.highlighted {
    background: #00d4aa;
    color: #0a0a0a;
    text-style: bold;
}

#recap-box {
    background: #1a1a2e;
    color: #e0e0e0;
    padding: 0 2;
}

#detail-header {
    height: auto;
    color: #666666;
    padding: 0 2;
}

#separator {
    height: auto;
    color: #666666;
}
