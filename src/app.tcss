SearchScreen {
    layout: vertical;
}

SearchScreen > Input {
    dock: top;
    height: 1;
    margin: 0 1;
    border: none;
    padding: 0 2;
}

SearchScreen > Input:focus {
    border: solid #00ffcc;
}

SearchScreen > #status-bar {
    dock: bottom;
    height: 1;
    background: #0a0a1a;
    color: #00d4aa;
    padding: 0 2;
}

SearchScreen > #results {
    border: none;
    margin: 0;
}

DetailScreen {
    layout: vertical;
}

DetailScreen > #detail-status {
    dock: bottom;
    height: 1;
    background: #0a0a1a;
    color: #00d4aa;
    padding: 0 2;
}

DetailScreen > #messages {
    border: none;
}

ListView {
    background: #1a1a2e;
    color: #c0c0c0;
}

ListView > ListItem {
    padding: 0 2;
}

ListView > ListItem.highlighted {
    background: #00d4aa;
    color: #0a0a0a;
    text-style: bold;
}

#recap-box {
    dock: top;
    background: #1a1a2e;
    color: #e0e0e0;
    padding: 0 2;
    height: auto;
}

#detail-header {
    dock: top;
    color: #888888;
    padding: 0 2;
    height: 1;
}

#separator {
    dock: top;
    color: #444444;
    height: 1;
}
